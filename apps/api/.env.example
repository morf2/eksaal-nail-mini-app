PORT=4000
# 'production' switches the admin session cookie to secure (HTTPS-only).
NODE_ENV=development
# PostgreSQL — required both locally and in production (schema provider is fixed
# to postgresql, not swappable per-environment). Point this at a local Postgres
# (e.g. `docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`) for
# dev, and at your Render Postgres instance's External/Internal Database URL in
# production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eksaal_nail"
CORS_ORIGIN=https://your-mini-app-domain.example

# Admin auth — verified server-side only now, never shipped to the frontend bundle.
# Generate the hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_LOGIN=master
ADMIN_PASSWORD_HASH=
SESSION_COOKIE_NAME=eksaal_admin_session

TELEGRAM_BOT_TOKEN=

MASTER_TIMEZONE=Europe/Moscow
CANCELLATION_THRESHOLD_HOURS=3

MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_MAX_REQUESTS=5

# S3-compatible bucket for portfolio photos (e.g. Cloudflare R2). S3_ENDPOINT is the
# API endpoint used for uploads (e.g. https://<accountid>.r2.cloudflarestorage.com).
# S3_PUBLIC_URL_BASE is the separate public read URL (R2 public bucket URL or custom
# domain) — S3-compatible providers' upload endpoint is not the same as the public
# read URL, so this can't be derived from S3_ENDPOINT.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL_BASE=
