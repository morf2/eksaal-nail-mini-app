generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Mirrors packages/shared/src/booking.ts Booking type. services/design/statusHistory
// are stored as JSON-serialized strings rather than normalized into their own
// tables — normalizing further is a deliberately deferred later step (see
// bookingServiceSchema comment in shared), not required for this phase's API contract.
model Booking {
  id               String   @id @default(cuid())
  clientId         String?
  clientName       String?
  telegramUsername String?
  telegramId       String?
  phone            String
  services         String
  date             String
  startTime        String
  endTime          String
  durationMinutes  Int
  totalPrice       Float
  design           String?
  coatingStatus    String?
  desiredLength    String?
  clientComment    String?
  status           String
  statusHistory    String
  createdAt        String
}

// One row per Telegram user who has ever sent /start to the bot. role is a plain
// string (not a Prisma enum — SQLite doesn't support them) and defaults to
// 'CLIENT'; nothing assigns 'MASTER' automatically yet — that's follow-up work
// once role-based notification routing actually exists.
model BotSubscriber {
  id        String   @id @default(cuid())
  chatId    String   @unique
  username  String?
  role      String
  createdAt String
}

// Mirrors packages/shared/src/portfolio.ts PortfolioItem type. The image itself is
// stored as bytes directly on the row (imageData) — no S3/R2, per project decision —
// re-encoded to WebP and capped at 1200px wide before storing (see
// apps/api/src/lib/image.ts) to keep this column from growing the DB too fast against
// Render Postgres' 1GB cap. Served back out through GET /portfolio/:id/image; the
// frontend-facing imageUrl on the DTO is that route's URL, built per-request in
// portfolio.mapper.ts — it isn't a column on this model.
model PortfolioItem {
  id               String   @id @default(cuid())
  imageData        Bytes
  imageContentType String
  title            String
  category         String
  description      String?
  isHidden         Boolean  @default(false)
  createdAt        String
}
